{
  "name": "shindo-launcher",
  "private": true,
  "version": "0.2.3",
  "license": "GPL-3.0-only",
  "author": "MikiDevAHM <miki@mittelsdorf.me>",
  "description": "Shindo Launcher desktop app",
  "authors": {
    "name": [
      "MikiDevAHM",
      "EaeDoonGG"
    ],
    "email": "miki@mittelsdorf.me"
  },
  "workspaces": [
    "packages/*"
  ],
  "type": "commonjs",
  "main": "dist/main/main.js",
  "scripts": {
    "dev": "node scripts/dev.js",
    "dev:renderer": "cd packages/renderer && vite",
    "dev:electron": "node scripts/dev-electron.js",
    "watch:main": "tsc -p packages/main/tsconfig.json --watch",
    "watch:preload": "tsc -p packages/preload/tsconfig.json --watch",
    "watch:shared": "tsc -p packages/shared/tsconfig.json --watch",
    "build:app": "bun clean && bun build:shared && bun build:preload && bun build:main && bun build:renderer",
    "build:shared": "tsc -p packages/shared/tsconfig.json",
    "build:preload": "tsc -p packages/preload/tsconfig.json",
    "build:main": "tsc -p packages/main/tsconfig.json",
    "build:renderer": "cd packages/renderer && vite build",
    "preview": "cd packages/renderer && vite preview",
    "clean": "rimraf dist",
    "package": "electron-builder --dir",
    "release:linux": "electron-builder --linux appimage --linux deb --publish=always",
    "release:windows": "electron-builder --win nsis --publish=always",
    "release:mac": "electron-builder --mac dmg --mac zip --publish=always",
    "lint": "echo \"TODO: add linting\"",
    "format": "prettier --write .",
    "start": "electron ."
  },
  "dependencies": {
    "@shindo/shared": "workspace:*",
    "electron-context-menu": "^4.1.1",
    "electron-reloader": "^1.2.3",
    "electron-serve": "^3.0.0",
    "electron-squirrel-startup": "^1.0.1",
    "electron-updater": "^6.3.9",
    "electron-window-state": "^5.0.3",
    "lucide-svelte": "^0.329.0",
    "minecraft-launcher-core": "^3.18.2",
    "node-fetch": "^3.3.2",
    "semver": "^7.7.3",
    "tar": "^6.2.0"
  },
  "devDependencies": {
    "@sveltejs/adapter-static": "^3.0.10",
    "@sveltejs/kit": "^2.47.2",
    "@sveltejs/vite-plugin-svelte": "^3.1.1",
    "@types/adm-zip": "^0.5.7",
    "@types/bun": "latest",
    "@types/node": "^22.10.1",
    "@types/semver": "^7.5.8",
    "@types/tar": "^6.1.13",
    "autoprefixer": "^10.4.16",
    "concurrently": "^8.2.2",
    "cross-env": "^7.0.3",
    "electron": "^29.3.0",
    "electron-builder": "^26.8.1",
    "electron-connect": "^0.6.3",
    "postcss": "^8.4.32",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "rimraf": "^5.0.5",
    "svelte": "^4.2.18",
    "svelte-check": "^3.8.5",
    "svelte-preprocess": "^6.0.3",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.6.3",
    "vite": "^5.0.11",
    "wait-on": "^7.2.0"
  },
  "trustedDependencies": [
    "@bitdisaster/exe-icon-extractor",
    "svelte-preprocess"
  ],
  "build": {
    "appId": "com.shindo.launcher",
    "productName": "Shindo Launcher",
    "asar": true,
    "directories": {
      "output": "release",
      "buildResources": "packages/renderer/src/assets"
    },
    "files": [
      "dist/main/**/*",
      "dist/preload/**/*",
      "dist/shared/**/*",
      "dist/renderer/**/*",
      "node_modules/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "packages/renderer/src/assets/logo.ico",
        "to": "logo.ico"
      },
      {
        "from": "packages/renderer/src/assets/logo.icns",
        "to": "logo.icns"
      },
      {
        "from": "packages/renderer/src/assets/logo.png",
        "to": "logo.png"
      }
    ],
    "publish": [
      {
        "provider": "github",
        "owner": "MikiDevAHM",
        "repo": "shindo-launcher"
      }
    ],
    "win": {
      "icon": "packages/renderer/src/assets/logo.ico",
      "target": [
        "nsis"
      ]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowElevation": true,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": "always",
      "createStartMenuShortcut": true,
      "shortcutName": "Shindo Launcher"
    },
    "mac": {
      "category": "public.app-category.games",
      "icon": "packages/renderer/src/assets/logo.icns",
      "target": [
        "dmg",
        "zip"
      ]
    },
    "linux": {
      "icon": "packages/renderer/src/assets/logo.png",
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "Game"
    }
  }
}
