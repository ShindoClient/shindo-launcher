{
  "name": "shindo-launcher",
  "private": true,
  "version": "0.3.0",
  "license": "GPL-3.0-only",
  "author": "MikiDevAHM <miki@mittelsdorf.me>",
  "description": "Shindo Client Launcher",
  "type": "commonjs",
  "main": "dist/main/main.js",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "node scripts/dev-electron.js",
    "start": "pnpm run dev",
    "build": "pnpm run build:shared && pnpm run build:preload && pnpm run build:main && pnpm run build:renderer",
    "build:shared": "pnpm exec tsc -p packages/shared/tsconfig.json",
    "build:preload": "pnpm exec tsc -p packages/preload/tsconfig.json",
    "build:main": "pnpm exec tsc -p packages/main/tsconfig.json",
    "build:renderer": "pnpm --dir packages/renderer exec vite build",
    "watch:main": "pnpm exec tsc -p packages/main/tsconfig.json --watch",
    "watch:shared": "pnpm exec tsc -p packages/shared/tsconfig.json --watch",
    "typecheck": "pnpm exec tsc --noEmit && pnpm --dir packages/renderer exec svelte-check",
    "clean": "rimraf dist packages/shared/dist packages/preload/dist packages/main/dist",
    "package": "pnpm run build && pnpm exec electron-builder --dir",
    "package:win": "pnpm run build && pnpm exec electron-builder --win nsis --publish=never",
    "package:win:l": "pnpm run build && pnpm exec electron-builder --win nsis --publish=never --config.directories.output=L:\\shindo-launcher-release",
    "release:linux": "pnpm run build && pnpm exec electron-builder --linux AppImage deb --publish=always",
    "release:windows": "pnpm run build && pnpm exec electron-builder --win nsis --publish=always",
    "release:mac": "pnpm run build && pnpm exec electron-builder --mac dmg zip --publish=always",
    "format": "prettier --write ."
  },
  "dependencies": {
    "@lucide/svelte": "^1.14.0",
    "@shindo/shared": "workspace:*",
    "adm-zip": "^0.5.17",
    "mime-db": "^1.52.0",
    "minecraft-launcher-core": "^3.18.2",
    "semver": "^7.8.0",
    "tar": "^6.2.1"
  },
  "devDependencies": {
    "@sveltejs/adapter-static": "^3.0.10",
    "@sveltejs/kit": "^2.59.1",
    "@sveltejs/vite-plugin-svelte": "^7.1.2",
    "@types/adm-zip": "^0.5.8",
    "@types/bun": "^1.3.14",
    "@types/node": "^22.19.19",
    "@types/semver": "^7.7.1",
    "@types/tar": "^6.1.13",
    "concurrently": "^9.2.1",
    "electron": "^36.9.5",
    "electron-builder": "^26.8.1",
    "esbuild": "^0.28.0",
    "png-to-ico": "^3.0.1",
    "prettier": "^3.8.3",
    "prettier-plugin-svelte": "^3.5.2",
    "rimraf": "^6.1.3",
    "sass-embedded": "^1.99.0",
    "svelte": "^5.55.5",
    "svelte-check": "^4.4.8",
    "tailwindcss": "^4.3.0",
    "typescript": "^5.9.3",
    "vite": "^8.0.12",
    "wait-on": "^9.0.10"
  },
  "build": {
    "appId": "com.shindoclient.launcher",
    "productName": "Shindo Launcher",
    "copyright": "Copyright © 2025 ShindoClient",
    "asar": true,
    "directories": {
      "output": "release",
      "buildResources": "."
    },
    "files": [
      "dist/**/*",
      "!dist/renderer/**/*.map"
    ],
    "extraResources": [
      {
        "from": "logo.png",
        "to": ".",
        "filter": [
          "logo.*"
        ]
      }
    ],
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "icon": "logo.png",
      "category": "Game"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "logo.ico"
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "icon": "logo.png",
      "category": "public.app-category.games"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowElevation": true,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": "always",
      "createStartMenuShortcut": true,
      "shortcutName": "Shindo Launcher"
    },
    "publish": {
      "provider": "github",
      "owner": "ShindoClient",
      "repo": "shindo-launcher",
      "releaseType": "release"
    }
  },
  "trustedDependencies": [
    "@parcel/watcher",
    "electron",
    "electron-winstaller",
    "esbuild"
  ]
}
